---
import { createHighlighter } from 'shiki';

const benefits = [
  {
    title: 'Version-controlled',
    description: 'Policies live in Git. Review changes in PRs. Roll back with confidence.',
  },
  {
    title: 'CI/CD native',
    description: 'Apply policies in your pipeline. No manual console clicks.',
  },
  {
    title: 'Terraform, Pulumi, or raw API',
    description: 'Use your existing IaC stack. We expose a simple RESTful API.',
  },
  {
    title: 'Drift detection',
    description: 'Detect when runtime state diverges from declared policy.',
  },
];

const apiFeatures = [
  'RESTful API with OpenAPI spec',
  'Idempotent policy updates',
  'Dry-run mode for validation',
  'Webhook notifications on changes',
];

const terraformCode = `resource "neuwerk_policy" "main" {
  name           = "prod-default"
  mode           = "enforce"
  default_action = "deny"

  source_group = [
    {
      id = "prod-cluster"

      sources = {
        cidrs = ["10.20.0.0/22"]
      }

      rule = [
        {
          id     = "allow-dns"
          action = "allow"
          dns = {
            exact = ["github.com"]
          }
        }
      ]
    }
  ]
}`;

const highlighter = await createHighlighter({
  themes: ['github-dark'],
  langs: ['hcl'],
});

const highlightedCode = highlighter.codeToHtml(terraformCode, {
  lang: 'hcl',
  theme: 'github-dark',
});
---

<section class="py-24 border-t border-slate-800">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-white">
        Policy as Code
      </h2>
      <p class="mt-4 text-lg text-slate-400">
        Define egress rules in Terraform, commit to Git, deploy via CI. No click-ops. No drift.
      </p>
    </div>

    <div class="mt-12 grid lg:grid-cols-2 gap-8">
      <!-- Benefits -->
      <div>
        <h3 class="text-lg font-semibold text-white mb-6">Infrastructure-native workflow</h3>
        <div class="space-y-6">
          {benefits.map((benefit, i) => (
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-brand-500/20 text-brand-400 flex items-center justify-center font-medium">
                {i + 1}
              </div>
              <div>
                <p class="font-medium text-white">{benefit.title}</p>
                <p class="text-sm text-slate-400">{benefit.description}</p>
              </div>
            </div>
          ))}
        </div>

        <div class="mt-8 p-4 rounded-lg bg-slate-800/50 border border-slate-700">
          <h4 class="text-sm font-medium text-white mb-3">API-first design</h4>
          <ul class="space-y-2">
            {apiFeatures.map((feature) => (
              <li class="flex items-center gap-2 text-sm text-slate-400">
                <svg class="w-4 h-4 text-emerald-400 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                <span>{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Terraform example -->
      <div>
        <h3 class="text-lg font-semibold text-white mb-6">Terraform Example</h3>
        <div class="bg-slate-900 rounded-xl border border-slate-700 overflow-hidden">
          <div class="px-4 py-2 bg-slate-800/50 border-b border-slate-700 flex items-center gap-2">
            <svg class="w-4 h-4 text-purple-400" viewBox="0 0 24 24" fill="currentColor">
              <path d="M1 5.6v5.8l5 2.9V8.5L1 5.6zm6 3v5.8l5 2.9V11.5l-5-2.9zm6-6.9v5.8l5 2.9V4.6l-5-2.9zm6 3v5.8l5 2.9V8.5l-5-2.9z"/>
            </svg>
            <span class="text-sm text-slate-400">egress.tf</span>
          </div>
          <div class="code-block p-4 text-sm overflow-x-auto [&_pre]:!bg-transparent [&_pre]:!p-0 [&_pre]:!m-0" set:html={highlightedCode} />
        </div>
      </div>
    </div>

    <!-- Why Policy as Code -->
    <div class="mt-12 p-6 rounded-xl bg-slate-800/50 border border-slate-700">
      <h3 class="text-lg font-semibold text-white mb-4">Why Policy as Code matters</h3>
      <div class="grid md:grid-cols-3 gap-6">
        <div>
          <h4 class="font-medium text-white">Audit trail built-in</h4>
          <p class="mt-1 text-sm text-slate-400">
            Every policy change is a Git commit. Who changed what, when, and why — answered by your existing tools.
          </p>
        </div>
        <div>
          <h4 class="font-medium text-white">No console access needed</h4>
          <p class="mt-1 text-sm text-slate-400">
            Engineers submit PRs. Security reviews and approves. No one needs admin access to a web UI.
          </p>
        </div>
        <div>
          <h4 class="font-medium text-white">Test before deploy</h4>
          <p class="mt-1 text-sm text-slate-400">
            Dry-run mode validates policies against your current traffic. Catch mistakes before they block production.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
