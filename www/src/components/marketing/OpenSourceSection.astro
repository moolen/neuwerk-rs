---
import CTAButton from '../common/CTAButton.astro';

const openSourceFeatures = [
  { feature: 'DPDK dataplane', status: 'available' },
  { feature: 'DNS proxy & resolver', status: 'available' },
  { feature: 'Policy engine', status: 'available' },
  { feature: 'API, web UI, and automation tooling', status: 'available' },
  { feature: 'SSO, service accounts, and HA cluster mode', status: 'available' },
];

const supportOptions = [
  'Design partner access for early rollouts',
  'Commercial support for deployment and migration work',
  'Operator reviews for audit-mode rollout plans',
  'Direct feedback loop on roadmap gaps',
];
---

<section class="relative py-24 border-t border-slate-800 bg-slate-900/70">
  <div class="relative mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-bold text-white">
        Open Source
      </h2>
      <p class="mt-4 text-xl text-slate-400">
        The dataplane, control plane, UI, and cluster features ship in the Apache 2.0 codebase. Build it, audit it, and run it without feature gates.
      </p>
    </div>

    <div class="mt-12 grid md:grid-cols-2 gap-8">
      <!-- Open Source -->
      <div class="p-6 rounded-xl bg-emerald-500/5 border border-emerald-500/20">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-emerald-500/20 flex items-center justify-center">
            <svg class="w-5 h-5 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-emerald-400">Open Source</h3>
            <p class="text-sm text-slate-400">Apache 2.0 License</p>
          </div>
        </div>

        <div class="space-y-3">
          {openSourceFeatures.map((item) => (
            <div class="flex items-center justify-between p-3 rounded-lg bg-slate-900/50">
              <span class="text-slate-300">{item.feature}</span>
              <span class="text-xs font-medium px-2 py-0.5 rounded bg-emerald-500/20 text-emerald-400">
                {item.status}
              </span>
            </div>
          ))}
        </div>

        <div class="mt-6">
          <CTAButton href="https://github.com/moolen/neuwerk" variant="secondary" size="md" class="w-full">
            <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
            </svg>
            View on GitHub
          </CTAButton>
        </div>
      </div>

      <!-- Support -->
      <div class="p-6 rounded-xl bg-slate-800/50 border border-slate-700">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-lg bg-slate-700 flex items-center justify-center">
            <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-semibold text-white">Support & Design Partners</h3>
            <p class="text-sm text-slate-400">Help with rollout, migration, and feedback loops</p>
          </div>
        </div>

        <ul class="space-y-3">
          {supportOptions.map((item) => (
            <li class="flex items-start gap-3 rounded-lg bg-slate-900/30 p-3">
              <div class="mt-0.5 flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-slate-700">
                <svg class="h-3 w-3 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
              <span class="text-slate-400">{item}</span>
            </li>
          ))}
        </ul>

        <div class="mt-6 p-4 rounded-lg bg-slate-900/50 border border-slate-700">
          <p class="text-sm text-slate-400">
            <strong class="text-white">No feature gating:</strong> SSO, clustering, and the policy engine are part of the OSS release.
            Support is about helping operators ship it safely, not hiding product capabilities.
          </p>
        </div>

        <div class="mt-6">
          <CTAButton href="mailto:hello@neuwerk.io?subject=Neuwerk%20Support%20Inquiry" variant="primary" size="md" class="w-full">
            Contact Engineering
          </CTAButton>
        </div>
      </div>
    </div>

    <div class="mt-12 text-center">
      <p class="text-lg text-slate-300">
        We believe security tools should be <strong class="text-white">inspectable</strong>.
        You can audit every line that touches your packets.
      </p>
    </div>
  </div>
</section>
