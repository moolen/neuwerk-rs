---
const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    title: 'Docs',
    links: [
      { href: '/docs', label: 'Overview' },
      { href: '/docs/tutorials/deploy-a-single-node', label: 'Getting Started' },
      { href: '/docs/architecture/system-overview', label: 'Explanations' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { href: '/blog', label: 'Blog' },
      { href: '/docs/reference/configuration-schema', label: 'Config Schema' },
      { href: '/docs/reference/ports-protocols', label: 'Ports & Protocols' },
    ],
  },
  {
    title: 'Project',
    links: [
      { href: 'https://github.com/moolen/neuwerk', label: 'GitHub', external: true },
      { href: '/docs/interfaces/http-api', label: 'HTTP API' },
      { href: '/docs/interfaces/terraform-provider', label: 'Terraform Provider' },
    ],
  },
];
---

<footer class="border-t border-slate-800 bg-slate-900">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Logo and description -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 text-white">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-brand-500 to-violet-400 text-white shadow-lg shadow-brand-500/25">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
          </span>
          <span class="text-lg font-semibold">Neuwerk</span>
        </a>
        <p class="mt-3 text-sm text-slate-400">
          Product documentation for deploying and operating Neuwerk.
        </p>
      </div>

      <!-- Link columns -->
      {footerLinks.map((column) => (
        <div>
          <h3 class="text-sm font-semibold text-white">{column.title}</h3>
          <ul class="mt-4 space-y-2">
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-slate-400 hover:text-white transition-colors"
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-slate-800">
      <p class="text-sm text-slate-500 text-center">
        &copy; {currentYear} Neuwerk. Code available under Apache 2.0.
      </p>
    </div>
  </div>
</footer>
