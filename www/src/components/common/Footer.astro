---
const currentYear = new Date().getFullYear();

const footerLinks = [
  {
    title: 'Docs',
    links: [
      { href: '/docs', label: 'Overview' },
      { href: '/docs/architecture/system-overview', label: 'Architecture' },
      { href: '/docs/operations/observability', label: 'Operations' },
    ],
  },
  {
    title: 'Resources',
    links: [
      { href: '/blog', label: 'Blog' },
      { href: '/docs/reference/configuration-schema', label: 'Config Schema' },
      { href: '/docs/reference/ports-protocols', label: 'Ports & Protocols' },
    ],
  },
  {
    title: 'Project',
    links: [
      { href: 'https://github.com/moolen/neuwerk', label: 'GitHub', external: true },
      { href: '/docs/interfaces/http-api', label: 'HTTP API' },
      { href: '/docs/interfaces/terraform-provider', label: 'Terraform Provider' },
    ],
  },
];
---

<footer class="border-t border-slate-800 bg-slate-900">
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <!-- Logo and description -->
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="flex items-center gap-2 text-white">
          <svg class="h-7 w-7" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M8 12L16 8L24 12V20L16 24L8 20V12Z" stroke="currentColor" stroke-width="2" fill="none"/>
            <path d="M16 8V24" stroke="currentColor" stroke-width="2"/>
            <path d="M8 12L24 20" stroke="currentColor" stroke-width="2"/>
            <path d="M24 12L8 20" stroke="currentColor" stroke-width="2"/>
          </svg>
          <span class="text-lg font-semibold">Neuwerk</span>
        </a>
        <p class="mt-3 text-sm text-slate-400">
          Documentation scaffold for the Neuwerk firewall repository.
        </p>
      </div>

      <!-- Link columns -->
      {footerLinks.map((column) => (
        <div>
          <h3 class="text-sm font-semibold text-white">{column.title}</h3>
          <ul class="mt-4 space-y-2">
            {column.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-slate-400 hover:text-white transition-colors"
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-slate-800">
      <p class="text-sm text-slate-500 text-center">
        &copy; {currentYear} Neuwerk. All rights reserved.
      </p>
    </div>
  </div>
</footer>
