# Neuwerk appliance bootstrap overrides
#
# This file is sourced by /opt/neuwerk/bin/neuwerk-bootstrap before the
# generated /etc/neuwerk/neuwerk.env is written on each service start.
#
# Use NEUWERK_BOOTSTRAP_* keys when the image should derive the final runtime
# values, and plain NEUWERK_* keys for advanced runtime pass-through settings.
#
# Examples:
# NEUWERK_BOOTSTRAP_MANAGEMENT_INTERFACE=eth0
# NEUWERK_BOOTSTRAP_DATA_INTERFACE=ens5
# NEUWERK_BOOTSTRAP_DATA_PLANE_MODE=dpdk
# NEUWERK_BOOTSTRAP_DATA_PLANE_SELECTOR=mac:aa:bb:cc:dd:ee:ff
# NEUWERK_BOOTSTRAP_DNS_TARGET_IPS=10.0.1.4
# NEUWERK_BOOTSTRAP_DNS_UPSTREAMS=10.0.0.2:53,10.0.0.3:53
# NEUWERK_BOOTSTRAP_CLOUD_PROVIDER=aws
# NEUWERK_BOOTSTRAP_DEFAULT_POLICY=deny
# NEUWERK_BOOTSTRAP_SNAT_MODE=auto
# NEUWERK_BOOTSTRAP_HTTP_BIND=10.0.1.4:8443
# NEUWERK_BOOTSTRAP_METRICS_BIND=0.0.0.0:8080
#
# Optional runtime pass-through examples:
# NEUWERK_INTEGRATION_MODE=aws-asg
# NEUWERK_AWS_REGION=eu-central-1
# NEUWERK_AWS_VPC_ID=vpc-0123456789abcdef0
# NEUWERK_AWS_ASG_NAME=neuwerk-asg
# NEUWERK_DPDK_WORKERS=4
# NEUWERK_EXTRA_ARGS=--cluster-bind 10.0.1.4:7000 --join 10.0.1.10:7000
