{
  "default_policy": "deny",
  "source_groups": [
    {
      "id": "pods",
      "priority": 10,
      "sources": {
        "kubernetes": [
          {
            "integration": "prod-k8s",
            "pod_selector": {
              "namespace": "apps",
              "match_labels": {
                "app": "api"
              }
            }
          }
        ]
      },
      "rules": [
        {
          "id": "allow-https",
          "priority": 10,
          "action": "allow",
          "mode": "enforce",
          "match": {
            "proto": "tcp",
            "dst_ports": [
              443
            ]
          }
        }
      ]
    }
  ]
}
