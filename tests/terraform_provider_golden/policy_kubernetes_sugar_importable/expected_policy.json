{
  "default_policy": "deny",
  "source_groups": [
    {
      "id": "pods",
      "priority": 10,
      "default_action": "deny",
      "sources": {
        "kubernetes": [
          {
            "integration": "prod-k8s",
            "pod_selector": {
              "namespace": "apps",
              "match_labels": {
                "app": "api",
                "tier": "backend"
              }
            }
          },
          {
            "integration": "prod-k8s",
            "node_selector": {
              "match_labels": {
                "nodepool": "blue"
              }
            }
          }
        ]
      },
      "rules": [
        {
          "id": "allow-https",
          "priority": 10,
          "action": "allow",
          "mode": "audit",
          "match": {
            "proto": "tcp",
            "dst_ports": [
              443
            ],
            "dst_ips": [
              "203.0.113.10"
            ]
          }
        }
      ]
    }
  ]
}
