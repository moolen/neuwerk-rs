#cloud-config
package_update: true
package_upgrade: false
packages:
  - dpdk
  - dpdk-dev
  - pciutils
  - numactl
  - driverctl
  - ripgrep
  - net-tools
  - ethtool
  - iputils-ping
  - traceroute
  - mtr-tiny
  - netcat-openbsd
  - tcpdump
  - lsof
  - strace
  - iproute2
  - jq
  - unzip
  - curl
  - ca-certificates
  - python3

write_files:
  - path: /usr/local/bin/neuwerk-firstboot.sh
    permissions: "0755"
    content: |
      #!/usr/bin/env bash
      set -euo pipefail

      STATE_DIR="/var/lib/neuwerk"
      CONFIG_MARKER="$STATE_DIR/bootstrap.configured"
      FIRSTBOOT_MARKER="$STATE_DIR/firstboot.complete"
      REBOOT_MARKER="$STATE_DIR/bootstrap.reboot"
      CONFIG_FILE="/etc/neuwerk/config.yaml"

      mkdir -p "$STATE_DIR"
      mkdir -p "$(dirname "$CONFIG_FILE")"

      log() {
        echo "[neuwerk-firstboot] $*"
      }

      normalize_mac() {
        echo "$1" | tr '[:upper:]' '[:lower:]' | tr -d ':-'
      }

      iface_driver() {
        local iface="$1"
        readlink -f "/sys/class/net/$${iface}/device/driver" 2>/dev/null | awk -F/ '{print $NF}'
      }

      ensure_grub_flag() {
        local flag="$1"
        local grub_files=(
          "/etc/default/grub"
          "/etc/default/grub.d/50-cloudimg-settings.cfg"
        )
        local file
        for file in "$${grub_files[@]}"; do
          if [ ! -f "$file" ]; then
            continue
          fi
          if grep -q "^GRUB_CMDLINE_LINUX=" "$file"; then
            if ! grep -q "^GRUB_CMDLINE_LINUX=.*$${flag}" "$file"; then
              sed -i "s/GRUB_CMDLINE_LINUX=\"/GRUB_CMDLINE_LINUX=\"$${flag} /" "$file"
            fi
          fi
          if grep -q "^GRUB_CMDLINE_LINUX_DEFAULT=" "$file"; then
            if ! grep -q "^GRUB_CMDLINE_LINUX_DEFAULT=.*$${flag}" "$file"; then
              sed -i "s/GRUB_CMDLINE_LINUX_DEFAULT=\"/GRUB_CMDLINE_LINUX_DEFAULT=\"$${flag} /" "$file"
            fi
          fi
        done
      }

      ensure_dataplane_dhcp() {
        local mgmt_mac="$1"
        local data_mac="$2"
        local netplan_file="/etc/netplan/50-neuwerk.yaml"
        cat > "$netplan_file" <<EOF_NETPLAN
      network:
        version: 2
        ethernets:
          mgmt0:
            match:
              macaddress: "$${mgmt_mac}"
            set-name: "mgmt0"
            dhcp4: true
            dhcp4-overrides:
              route-metric: 100
            dhcp6: false
            nameservers:
              addresses:
                - 169.254.169.254
          data0:
            match:
              macaddress: "$${data_mac}"
            set-name: "data0"
            dhcp4: true
            dhcp4-overrides:
              use-dns: false
              route-metric: 200
            dhcp6: false
            optional: true
      EOF_NETPLAN
        chown root:root "$netplan_file"
        chmod 600 "$netplan_file"
        rm -f /etc/netplan/50-cloud-init.yaml /etc/netplan/60-neuwerk-dataplane.yaml
        netplan apply || true
      }

      disable_rp_filter() {
        cat > /etc/sysctl.d/91-neuwerk-multi-nic.conf <<EOF_SYSCTL
      net.ipv4.conf.all.rp_filter=0
      net.ipv4.conf.default.rp_filter=0
      net.ipv4.conf.mgmt0.rp_filter=0
      net.ipv4.conf.data0.rp_filter=0
      EOF_SYSCTL
        sysctl -p /etc/sysctl.d/91-neuwerk-multi-nic.conf || true
      }

      ensure_mgmt_vpc_route() {
        local cidr="$1"
        local gw=""
        gw=$(ip -4 route show dev mgmt0 | awk '$1 ~ /^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+\/[0-9]+$/ && $3 ~ /^[0-9]+\./ {print $3; exit}')
        if [ -z "$gw" ]; then
          gw=$(ip -4 route show dev mgmt0 | awk '$1 == "default" && $3 ~ /^[0-9]+\./ {print $3; exit}')
        fi
        if [ -n "$gw" ]; then
          ip route replace "$cidr" via "$gw" dev mgmt0 metric 50 || true
        else
          log "failed to derive management gateway; skipping VPC route install"
        fi
      }

      ensure_mgmt_default_route() {
        local gw=""
        gw=$(ip -4 route show dev mgmt0 | awk '$1 ~ /^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+\/[0-9]+$/ && $3 ~ /^[0-9]+\./ {print $3; exit}')
        if [ -z "$gw" ]; then
          gw=$(ip -4 route show dev mgmt0 | awk '$1 == "default" && $3 ~ /^[0-9]+\./ {print $3; exit}')
        fi
        if [ -n "$gw" ]; then
          # Keep management/control-plane reachability after dataplane NIC is moved to VFIO.
          ip route replace default via "$gw" dev mgmt0 metric 50 || true
        else
          log "failed to derive management gateway; skipping default route pin"
        fi
      }

      iface_for_cidr() {
        local cidr="$1"
        python3 - "$cidr" <<'PY'
      import ipaddress
      import json
      import subprocess
      import sys

      cidr = ipaddress.ip_network(sys.argv[1], strict=False)
      data = json.loads(subprocess.check_output(["ip", "-j", "-4", "addr", "show"]))
      for item in data:
          name = item.get("ifname", "")
          if not name or name == "lo":
              continue
          for info in item.get("addr_info", []):
              if info.get("family") != "inet":
                  continue
              local = info.get("local")
              if not local:
                  continue
              if ipaddress.ip_address(local) in cidr:
                  print(name)
                  raise SystemExit(0)
      raise SystemExit(1)
      PY
      }

      metadata_get() {
        local path="$1"
        curl -fsS --connect-timeout 2 --max-time 5 -H "Metadata-Flavor: Google" "http://169.254.169.254/computeMetadata/v1/$${path}"
      }

      wait_for_dns() {
        local host="$1"
        local attempts="$2"
        local sleep_secs="$3"
        local attempt
        for attempt in $(seq 1 "$attempts"); do
          if getent ahostsv4 "$host" >/dev/null 2>&1; then
            return 0
          fi
          log "waiting for DNS resolution of $${host} (attempt $${attempt}/$${attempts})"
          sleep "$sleep_secs"
        done
        return 1
      }

      gcs_download_with_retry() {
        local url="$1"
        local output="$2"
        local retries="$3"
        local attempt
        for attempt in $(seq 1 "$retries"); do
          ensure_metadata_route || true
          wait_for_dns "storage.googleapis.com" 3 1 || true
          if curl -fsSL -H "Authorization: Bearer $${TOKEN}" "$url" -o "$output"; then
            return 0
          fi
          log "download failed for $${url}; retrying ($${attempt}/$${retries})"
          sleep 2
        done
        return 1
      }

      ensure_metadata_route() {
        local meta_ip="169.254.169.254"
        if ip route get "$${meta_ip}" >/dev/null 2>&1; then
          return 0
        fi

        local iface
        for iface in "$${MGMT_IFACE:-}" "$${DATA_IFACE:-}" mgmt0 data0; do
          if [ -z "$iface" ]; then
            continue
          fi
          if ! ip link show "$iface" >/dev/null 2>&1; then
            continue
          fi
          ip route replace "$${meta_ip}"/32 dev "$iface" scope link || true
          if ip route get "$${meta_ip}" >/dev/null 2>&1; then
            return 0
          fi
        done
        return 1
      }

      if [ ! -f "$CONFIG_MARKER" ]; then
        log "configuring hugepages and IOMMU"
        local_cpu=$(lscpu | awk -F: '/Vendor ID/ {gsub(/ /, "", $2); print $2}')
        if [ "$local_cpu" = "AuthenticAMD" ]; then
          ensure_grub_flag "amd_iommu=on iommu=pt"
        else
          ensure_grub_flag "intel_iommu=on iommu=pt"
        fi
        ensure_grub_flag "default_hugepagesz=2M"
        ensure_grub_flag "hugepagesz=2M"
        ensure_grub_flag "hugepages=2048"
        echo "vm.nr_hugepages=2048" > /etc/sysctl.d/90-hugepages.conf
        sysctl -p /etc/sysctl.d/90-hugepages.conf || true
        update-grub
        touch "$CONFIG_MARKER"
        touch "$REBOOT_MARKER"
        log "rebooting after kernel parameter updates"
        systemctl reboot
        exit 0
      fi

      if [ -f "$CONFIG_MARKER" ]; then
        local_cpu=$(lscpu | awk -F: '/Vendor ID/ {gsub(/ /, "", $2); print $2}')
        if [ "$local_cpu" = "AuthenticAMD" ]; then
          IOMMU_FLAG="amd_iommu=on"
        else
          IOMMU_FLAG="intel_iommu=on"
        fi
        if ! grep -q "$IOMMU_FLAG" /proc/cmdline || ! grep -q "iommu=pt" /proc/cmdline; then
          log "IOMMU flags missing from /proc/cmdline; reconfiguring grub and rebooting"
          ensure_grub_flag "$IOMMU_FLAG iommu=pt"
          ensure_grub_flag "iommu=pt"
          ensure_grub_flag "default_hugepagesz=2M"
          ensure_grub_flag "hugepagesz=2M"
          ensure_grub_flag "hugepages=2048"
          update-grub
          touch "$REBOOT_MARKER"
          systemctl reboot
          exit 0
        fi
      fi

      if [ -f "$REBOOT_MARKER" ]; then
        rm -f "$REBOOT_MARKER"
      fi

      if [ -f "$BOOTSTRAP_MARKER" ]; then
        exit 0
      fi

      if [ -d /sys/kernel/iommu_groups ] && [ -z "$(ls -A /sys/kernel/iommu_groups 2>/dev/null)" ]; then
        log "no IOMMU groups detected; enabling vfio unsafe no-IOMMU mode"
        modprobe vfio enable_unsafe_noiommu_mode=1 || true
        if [ -w /sys/module/vfio/parameters/enable_unsafe_noiommu_mode ]; then
          echo 1 > /sys/module/vfio/parameters/enable_unsafe_noiommu_mode || true
        fi
      else
        modprobe vfio || true
      fi
      modprobe vfio-pci || true
      modprobe vfio_iommu_type1 || true

      MGMT_IFACE=$(iface_for_cidr "${mgmt_subnet_cidr}" || true)
      DATA_IFACE=$(iface_for_cidr "${dataplane_subnet_cidr}" || true)

      if [ -z "$MGMT_IFACE" ]; then
        MGMT_IFACE=$(ip route show default | awk '{print $5}' | head -n1)
      fi
      if [ -z "$MGMT_IFACE" ]; then
        MGMT_IFACE=$(ip -4 -o addr show | awk '$2 != "lo" {print $2; exit}')
      fi

      if [ -z "$DATA_IFACE" ]; then
        DATA_IFACE=$(ip -4 -o addr show | awk -v mgmt="$MGMT_IFACE" '$2 != "lo" && $2 != mgmt {print $2; exit}')
      fi

      if [ -z "$MGMT_IFACE" ] || [ -z "$DATA_IFACE" ]; then
        log "failed to identify management/dataplane interfaces (mgmt=$${MGMT_IFACE:-}, data=$${DATA_IFACE:-})"
        ip -4 -o addr show || true
        exit 1
      fi

      MGMT_MAC=$(cat "/sys/class/net/$${MGMT_IFACE}/address" 2>/dev/null || true)
      DATA_MAC=$(cat "/sys/class/net/$${DATA_IFACE}/address" 2>/dev/null || true)
      if [ -z "$MGMT_MAC" ] || [ -z "$DATA_MAC" ]; then
        log "failed to resolve interface MAC addresses"
        exit 1
      fi

      ensure_dataplane_dhcp "$MGMT_MAC" "$DATA_MAC"
      ip link set data0 up || true
      ensure_mgmt_vpc_route "${vpc_cidr}"
      ensure_mgmt_default_route
      disable_rp_filter
      ensure_metadata_route || log "metadata route not ready yet; will retry during token fetch"

      DATA_DRIVER=$(iface_driver "data0")
      DATA_PCI=""
      DATA_PCI_PATH=$(readlink -f /sys/class/net/data0/device 2>/dev/null || true)
      if [ -n "$DATA_PCI_PATH" ]; then
        DATA_PCI=$(basename "$DATA_PCI_PATH")
      fi
      DATA_STATIC_IP=$(ip -4 -o addr show dev data0 | awk '{print $4}' | cut -d/ -f1 | head -n1)
      DATA_STATIC_PREFIX=""
      DATA_STATIC_GATEWAY=""
      DATA_ROUTE=$(ip -4 route show dev data0 | awk '$1 ~ /^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+\/[0-9]+$/ && $3 ~ /^[0-9]+\./ {print $1 " " $3; exit}')
      if [ -n "$DATA_ROUTE" ]; then
        DATA_STATIC_PREFIX=$(echo "$DATA_ROUTE" | awk '{print $1}' | cut -d/ -f2)
        DATA_STATIC_GATEWAY=$(echo "$DATA_ROUTE" | awk '{print $2}')
      fi

      DATA_IFACE_SELECTOR="mac:$${DATA_MAC}"
      DPDK_DEVBIND="/usr/bin/dpdk-devbind.py"
      if [ ! -x "$DPDK_DEVBIND" ]; then
        DPDK_DEVBIND="/usr/share/dpdk/usertools/dpdk-devbind.py"
      fi

      TOKEN=""
      for attempt in $(seq 1 15); do
        ensure_metadata_route || true
        TOKEN=$(metadata_get "instance/service-accounts/default/token" | jq -r '.access_token // empty' || true)
        if [ -n "$TOKEN" ]; then
          break
        fi
        log "waiting for metadata token (attempt $${attempt}/15)"
        sleep 2
      done
      if [ -z "$TOKEN" ]; then
        log "failed to obtain metadata token"
        exit 1
      fi

      OBJ_ESC=$(python3 - <<'PY'
      import urllib.parse
      print(urllib.parse.quote("${gcs_object}", safe=""))
      PY
      )
      FW_URL="https://storage.googleapis.com/storage/v1/b/${gcs_bucket}/o/$${OBJ_ESC}?alt=media"
      log "downloading neuwerk binary from GCS"
      if ! gcs_download_with_retry "$FW_URL" /usr/local/bin/neuwerk 20; then
        log "failed to download neuwerk binary from GCS"
        exit 1
      fi
      chmod +x /usr/local/bin/neuwerk

      DPDK_OBJ_ESC=$(python3 - <<'PY'
      import urllib.parse
      print(urllib.parse.quote("${gcs_dpdk_object}", safe=""))
      PY
      )
      DPDK_URL="https://storage.googleapis.com/storage/v1/b/${gcs_bucket}/o/$${DPDK_OBJ_ESC}?alt=media"
      log "downloading dpdk runtime bundle from GCS"
      mkdir -p /opt/neuwerk/runtime
      if ! gcs_download_with_retry "$DPDK_URL" /tmp/neuwerk-dpdk-runtime.tgz 20; then
        log "failed to download dpdk runtime bundle from GCS"
        exit 1
      fi
      tar -xzf /tmp/neuwerk-dpdk-runtime.tgz -C /opt/neuwerk/runtime
      rm -f /tmp/neuwerk-dpdk-runtime.tgz
      if [ -f /opt/neuwerk/runtime/usr/lib/dpdk/pmds-26.0/librte_net_gve.so.26 ]; then
        ln -sf /opt/neuwerk/runtime/usr/lib/dpdk/pmds-26.0/librte_net_gve.so.26 \
          /opt/neuwerk/runtime/usr/lib/dpdk/pmds-26.0/librte_net_gve.so
      fi

      if [ -n "$DATA_PCI" ] && [ -e "/sys/bus/pci/devices/$${DATA_PCI}" ]; then
        if [ "${cloud_provider}" = "gcp" ] || [ "$DATA_DRIVER" = "gve" ]; then
          if [ ! -x "$DPDK_DEVBIND" ]; then
            log "dpdk-devbind missing; falling back to pci selector for $${DATA_PCI}"
            DATA_IFACE_SELECTOR="pci:$${DATA_PCI}"
          else
            ip link set data0 down || true
            bound_ok=0
            for attempt in $(seq 1 10); do
              if python3 "$DPDK_DEVBIND" -b vfio-pci "$DATA_PCI"; then
                bound_ok=1
                break
              fi
              log "dpdk-devbind failed for $${DATA_PCI}; retrying ($${attempt}/10)"
              sleep 1
            done
            if [ "$bound_ok" -ne 1 ]; then
              log "dpdk-devbind failed for $${DATA_PCI}; cannot continue with gcp dpdk dataplane"
              exit 1
            fi
            DATA_IFACE_SELECTOR="pci:$${DATA_PCI}"
          fi
        elif [ -x "$DPDK_DEVBIND" ]; then
          ip link set data0 down || true
          if python3 "$DPDK_DEVBIND" -b vfio-pci "$DATA_PCI"; then
            DATA_IFACE_SELECTOR="pci:$${DATA_PCI}"
          else
            log "dpdk-devbind failed for $${DATA_PCI}; falling back to mac selector"
            ip link set data0 up || true
          fi
        else
          DATA_IFACE_SELECTOR="pci:$${DATA_PCI}"
        fi
      fi

      log "dataplane selection: iface=data0 selector=$${DATA_IFACE_SELECTOR} driver=$${DATA_DRIVER} pci=$${DATA_PCI}"
      if [ -n "$DATA_STATIC_IP" ] && [ -n "$DATA_STATIC_PREFIX" ] && [ -n "$DATA_STATIC_GATEWAY" ]; then
        log "dataplane static config: ip=$${DATA_STATIC_IP} prefix=$${DATA_STATIC_PREFIX} gateway=$${DATA_STATIC_GATEWAY} mac=$${DATA_MAC}"
      fi

      MGMT_IP=""
      for attempt in $(seq 1 20); do
        MGMT_IP=$(ip -4 -o addr show dev mgmt0 | awk '{print $4}' | cut -d/ -f1 | head -n1)
        if [ -n "$MGMT_IP" ]; then
          break
        fi
        sleep 1
      done
      if [ -z "$MGMT_IP" ]; then
        log "failed to resolve management IP"
        exit 1
      fi

      DPDK_WORKERS="${dpdk_workers}"
      if ! [[ "$DPDK_WORKERS" =~ ^[0-9]+$ ]]; then
        DPDK_WORKERS=0
      fi
      GCP_IOVA_MODE=""
      if [ "${cloud_provider}" = "gcp" ]; then
        GCP_IOVA_MODE="pa"
      fi

      cat > "$CONFIG_FILE" <<EOF_CONFIG
      version: 1
      bootstrap:
        management_interface: "mgmt0"
        data_interface: "$${DATA_IFACE_SELECTOR}"
        cloud_provider: ${cloud_provider}
        data_plane_mode: dpdk
      dns:
        target_ips:
%{ for dns_target in dns_target_ips ~}
          - ${dns_target}
%{ endfor ~}
        upstreams:
%{ for dns_upstream in dns_upstreams ~}
          - "${dns_upstream}"
%{ endfor ~}
      policy:
        default: allow
        internal_cidr: ${internal_cidr}
      http:
        bind: "$${MGMT_IP}:8443"
        advertise: "$${MGMT_IP}:8443"
        external_url: "https://$${MGMT_IP}:8443"
      metrics:
        bind: "0.0.0.0:8080"
        allow_public_bind: true
      integration:
        mode: gcp-mig
        drain_timeout_secs: 30
        reconcile_interval_secs: 15
        gcp:
          project: ${gcp_project}
          region: ${gcp_region}
          ig_name: ${gcp_ig_name}
      dataplane:
        snat: ${snat_mode}
        admission:
          max_active_flows: 24576
          max_active_nat_entries: 24576
          max_pending_tls_flows: 2048
          max_active_flows_per_source_group: 16384
      dpdk:
%{ if dpdk_workers > 0 ~}
        workers: ${dpdk_workers}
%{ endif ~}
%{ if cloud_provider == "gcp" ~}
        iova_mode: pa
%{ endif ~}
      EOF_CONFIG

      if [ -n "$DATA_STATIC_IP" ] && [ -n "$DATA_STATIC_PREFIX" ] && [ -n "$DATA_STATIC_GATEWAY" ]; then
        cat >> "$CONFIG_FILE" <<EOF_DPDK_STATIC
        static_ip: $${DATA_STATIC_IP}
        static_prefix_len: $${DATA_STATIC_PREFIX}
        static_gateway: $${DATA_STATIC_GATEWAY}
        static_mac: "$${DATA_MAC}"
      EOF_DPDK_STATIC
      fi

      touch "$FIRSTBOOT_MARKER"
      systemctl daemon-reload
      systemctl reset-failed neuwerk.service || true
      systemctl restart neuwerk.service --no-block

  - path: /etc/systemd/system/neuwerk-firstboot.service
    permissions: "0644"
    content: |
      [Unit]
      Description=Neuwerk first boot preparation
      After=network-online.target
      Wants=network-online.target

      [Service]
      Type=oneshot
      ExecStart=/usr/local/bin/neuwerk-firstboot.sh
      RemainAfterExit=yes

      [Install]
      WantedBy=multi-user.target

  - path: /etc/systemd/system/neuwerk.service
    permissions: "0644"
    content: |
      [Unit]
      Description=Neuwerk
      After=network-online.target neuwerk-firstboot.service
      Wants=network-online.target
      Requires=neuwerk-firstboot.service

      [Service]
      Type=simple
      Environment=LD_LIBRARY_PATH=/opt/neuwerk/runtime/usr/lib:/opt/neuwerk/runtime/usr/lib/dpdk/pmds-26.0
      Environment=RTE_EAL_PMD_PATH=/opt/neuwerk/runtime/usr/lib/dpdk/pmds-26.0
      ExecStart=/usr/local/bin/neuwerk
      Restart=on-failure
      LimitMEMLOCK=infinity

      [Install]
      WantedBy=multi-user.target

runcmd:
  - systemctl daemon-reload
  - systemctl enable neuwerk-firstboot.service
  - systemctl enable neuwerk.service
  - systemctl start neuwerk-firstboot.service
