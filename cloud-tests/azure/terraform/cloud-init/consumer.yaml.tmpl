#cloud-config
package_update: true
package_upgrade: false
packages:
  - curl
  - dnsutils
  - ethtool
  - iproute2
  - iperf3
  - socat
  - wrk
  - jq
  - tcpdump
write_files:
  - path: /etc/apt/apt.conf.d/99force-ipv4
    permissions: "0644"
    content: |
      Acquire::ForceIPv4 "true";
%{ if secondary_private_ip_count > 0 ~}
  - path: /usr/local/sbin/azure-consumer-secondary-ips
    permissions: "0755"
    content: |
      #!/usr/bin/env bash
      set -euo pipefail

      metadata_url="http://169.254.169.254/metadata/instance/network/interface?api-version=2021-02-01"
      metadata_json="$(curl -fsS -H Metadata:true "$metadata_url")"
      configured_secondary_count=0

      while IFS= read -r iface; do
        [ -n "$iface" ] || continue
        mac_addr="$(cat "/sys/class/net/$iface/address" 2>/dev/null | tr '[:upper:]' '[:lower:]')"
        [ -n "$mac_addr" ] || continue

        prefix_len="$(ip -4 -o addr show dev "$iface" scope global primary | awk 'NR==1 {split($4, cidr, \"/\"); print cidr[2]}')"
        if [ -z "$prefix_len" ]; then
          prefix_len="$(ip -4 -o addr show dev "$iface" scope global | awk 'NR==1 {split($4, cidr, \"/\"); print cidr[2]}')"
        fi
        [ -n "$prefix_len" ] || continue

        primary_ip="$(ip -4 -o addr show dev "$iface" scope global primary | awk 'NR==1 {split($4, cidr, \"/\"); print cidr[1]}')"
        if [ -z "$primary_ip" ]; then
          primary_ip="$(ip -4 -o addr show dev "$iface" scope global | awk 'NR==1 {split($4, cidr, \"/\"); print cidr[1]}')"
        fi
        [ -n "$primary_ip" ] || continue

        while IFS= read -r private_ip; do
          [ -n "$private_ip" ] || continue
          if [ "$private_ip" = "$primary_ip" ]; then
            continue
          fi
          configured_secondary_count=$((configured_secondary_count + 1))
          if ip -4 -o addr show dev "$iface" to "$private_ip" | grep -Fq "$private_ip/"; then
            continue
          fi
          ip addr replace "$private_ip/$prefix_len" dev "$iface"
        done < <(
          jq -r --arg mac "$mac_addr" '
            map(select((.macAddress // "" | ascii_downcase) == $mac))
            | .[0].ipv4.ipAddress[]?.privateIpAddress // empty
          ' <<<"$metadata_json"
        )
      done < <(ip -o link show | awk -F': ' '$2 != "lo" {print $2}')

      if [ "$configured_secondary_count" -lt ${secondary_private_ip_count} ]; then
        echo "expected at least ${secondary_private_ip_count} secondary private IPs across consumer interfaces, found $configured_secondary_count" >&2
        exit 1
      fi
  - path: /etc/systemd/system/azure-consumer-secondary-ips.service
    permissions: "0644"
    content: |
      [Unit]
      Description=Configure Azure consumer secondary private IPs
      Wants=network-online.target
      After=network-online.target

      [Service]
      Type=oneshot
      ExecStart=/usr/local/sbin/azure-consumer-secondary-ips
      RemainAfterExit=true

      [Install]
      WantedBy=multi-user.target
%{ endif ~}

runcmd:
  - PRIMARY_IFACE="$(ip route show default | awk '/default/ {print $5; exit}')"; if [ -n "$PRIMARY_IFACE" ]; then ethtool -K "$PRIMARY_IFACE" rx off tx off gro off gso off tso off lro off || true; fi
%{ if secondary_private_ip_count > 0 ~}
  - systemctl daemon-reload
  - systemctl enable --now azure-consumer-secondary-ips.service
%{ endif ~}
