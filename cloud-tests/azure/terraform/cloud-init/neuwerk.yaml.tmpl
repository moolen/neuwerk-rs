#cloud-config
package_update: true
package_upgrade: false
packages:
  - dpdk
  - dpdk-dev
  - pciutils
  - numactl
  - driverctl
  - ripgrep
  - net-tools
  - ethtool
  - iputils-ping
  - traceroute
  - mtr-tiny
  - netcat-openbsd
  - tcpdump
  - lsof
  - strace
  - iproute2
  - jq
  - unzip
  - curl
  - ca-certificates
  - python3
  - python3-yaml

write_files:
  - path: /usr/local/bin/neuwerk-firstboot.sh
    permissions: "0755"
    content: |
      #!/usr/bin/env bash
      set -euo pipefail

      STATE_DIR="/var/lib/neuwerk"
      CONFIG_MARKER="$STATE_DIR/bootstrap.configured"
      FIRSTBOOT_MARKER="$STATE_DIR/firstboot.complete"
      REBOOT_MARKER="$STATE_DIR/bootstrap.reboot"
      CONFIG_FILE="/etc/neuwerk/config.yaml"
      HEALTH_ROUTE_STATE="$STATE_DIR/azure-health-route.yaml"

      mkdir -p "$STATE_DIR"
      mkdir -p "$(dirname "$CONFIG_FILE")"

      log() {
        echo "[neuwerk-firstboot] $*"
      }

      if ! dpkg -s "linux-modules-extra-$(uname -r)" >/dev/null 2>&1; then
        log "installing linux-modules-extra for current kernel"
        apt-get update -y
        apt-get install -y "linux-modules-extra-$(uname -r)"
      fi

      normalize_mac() {
        echo "$1" | tr '[:upper:]' '[:lower:]' | tr -d ':-'
      }

      iface_for_mac() {
        local target
        target=$(normalize_mac "$1")
        for iface in /sys/class/net/*; do
          iface=$(basename "$iface")
          if [ "$iface" = "lo" ]; then
            continue
          fi
          local mac
          mac=$(cat "/sys/class/net/$${iface}/address" 2>/dev/null || true)
          if [ -z "$mac" ]; then
            continue
          fi
          if [ "$(normalize_mac "$mac")" = "$target" ]; then
            echo "$iface"
            return 0
          fi
        done
        return 1
      }

      iface_driver() {
        local iface="$1"
        readlink -f "/sys/class/net/$${iface}/device/driver" 2>/dev/null | awk -F/ '{print $NF}'
      }

      ensure_grub_flag() {
        local flag="$1"
        local grub_files=(
          "/etc/default/grub"
          "/etc/default/grub.d/50-cloudimg-settings.cfg"
        )
        local file
        for file in "$${grub_files[@]}"; do
          if [ ! -f "$file" ]; then
            continue
          fi
          if grep -q "^GRUB_CMDLINE_LINUX=" "$file"; then
            if ! grep -q "^GRUB_CMDLINE_LINUX=.*$${flag}" "$file"; then
              sed -i "s/GRUB_CMDLINE_LINUX=\"/GRUB_CMDLINE_LINUX=\"$${flag} /" "$file"
            fi
          fi
          if grep -q "^GRUB_CMDLINE_LINUX_DEFAULT=" "$file"; then
            if ! grep -q "^GRUB_CMDLINE_LINUX_DEFAULT=.*$${flag}" "$file"; then
              sed -i "s/GRUB_CMDLINE_LINUX_DEFAULT=\"/GRUB_CMDLINE_LINUX_DEFAULT=\"$${flag} /" "$file"
            fi
          fi
        done
      }

      ensure_dataplane_dhcp() {
        local mgmt_mac="$1"
        local data_mac="$2"
        local data_dhcp="$${3:-true}"
        local netplan_file="/etc/netplan/50-neuwerk.yaml"
        cat > "$netplan_file" <<EOF_NETPLAN
      network:
        version: 2
        ethernets:
          eth0:
            match:
              macaddress: "$${mgmt_mac}"
            set-name: "eth0"
            dhcp4: true
            dhcp4-overrides:
              route-metric: 100
            dhcp6: false
          data0:
            match:
              macaddress: "$${data_mac}"
            set-name: "data0"
      EOF_NETPLAN
        if [ "$data_dhcp" = "true" ]; then
          cat >> "$netplan_file" <<EOF_NETPLAN
            dhcp4: true
            dhcp4-overrides:
              use-dns: false
              route-metric: 200
      EOF_NETPLAN
        else
          cat >> "$netplan_file" <<EOF_NETPLAN
            dhcp4: false
      EOF_NETPLAN
        fi
        cat >> "$netplan_file" <<EOF_NETPLAN
            dhcp6: false
            optional: true
      EOF_NETPLAN
        chown root:root "$netplan_file"
        chmod 600 "$netplan_file"
        rm -f /etc/netplan/50-cloud-init.yaml /etc/netplan/60-neuwerk-dataplane.yaml
        netplan apply || true
      }

      if [ ! -f "$CONFIG_MARKER" ]; then
        log "configuring hugepages and IOMMU"
        local_cpu=$(lscpu | awk -F: '/Vendor ID/ {gsub(/ /, "", $2); print $2}')
        if [ "$local_cpu" = "AuthenticAMD" ]; then
          ensure_grub_flag "amd_iommu=on iommu=pt"
        else
          ensure_grub_flag "intel_iommu=on iommu=pt"
        fi
        ensure_grub_flag "default_hugepagesz=2M"
        ensure_grub_flag "hugepagesz=2M"
        ensure_grub_flag "hugepages=2048"
        echo "vm.nr_hugepages=2048" > /etc/sysctl.d/90-hugepages.conf
        sysctl -p /etc/sysctl.d/90-hugepages.conf || true
        update-grub
        touch "$CONFIG_MARKER"
        touch "$REBOOT_MARKER"
        log "rebooting after kernel parameter updates"
        systemctl reboot
        exit 0
      fi

      if [ -f "$CONFIG_MARKER" ]; then
        local_cpu=$(lscpu | awk -F: '/Vendor ID/ {gsub(/ /, "", $2); print $2}')
        if [ "$local_cpu" = "AuthenticAMD" ]; then
          IOMMU_FLAG="amd_iommu=on"
        else
          IOMMU_FLAG="intel_iommu=on"
        fi
        if ! grep -q "$IOMMU_FLAG" /proc/cmdline || ! grep -q "iommu=pt" /proc/cmdline; then
          log "IOMMU flags missing from /proc/cmdline; reconfiguring grub and rebooting"
          ensure_grub_flag "$IOMMU_FLAG iommu=pt"
          ensure_grub_flag "iommu=pt"
          ensure_grub_flag "default_hugepagesz=2M"
          ensure_grub_flag "hugepagesz=2M"
          ensure_grub_flag "hugepages=2048"
          update-grub
          touch "$REBOOT_MARKER"
          systemctl reboot
          exit 0
        fi
      fi

      if [ -f "$REBOOT_MARKER" ]; then
        rm -f "$REBOOT_MARKER"
      fi

      if [ -f "$BOOTSTRAP_MARKER" ]; then
        exit 0
      fi

      if [ -d /sys/kernel/iommu_groups ] && [ -z "$(ls -A /sys/kernel/iommu_groups 2>/dev/null)" ]; then
        log "no IOMMU groups detected; enabling vfio unsafe no-IOMMU mode"
        if ! modprobe vfio enable_unsafe_noiommu_mode=1; then
          log "modprobe vfio failed; continuing without vfio"
        fi
        if [ -w /sys/module/vfio/parameters/enable_unsafe_noiommu_mode ]; then
          echo 1 > /sys/module/vfio/parameters/enable_unsafe_noiommu_mode || true
        fi
      else
        if ! modprobe vfio; then
          log "modprobe vfio failed; continuing without vfio"
        fi
      fi
      if ! modprobe vfio-pci; then
        log "modprobe vfio-pci failed; continuing without vfio"
      fi
      if ! modprobe vfio_iommu_type1; then
        log "modprobe vfio_iommu_type1 failed; continuing without vfio"
      fi

      METADATA_BASE="http://169.254.169.254/metadata/instance"
      META_COMP=""
      for attempt in $(seq 1 10); do
        META_COMP=$(curl -s -H Metadata:true "$${METADATA_BASE}/compute?api-version=2021-02-01" || true)
        if echo "$META_COMP" | jq -e . >/dev/null 2>&1; then
          break
        fi
        log "waiting for IMDS compute metadata (attempt $${attempt}/10)"
        sleep 2
      done
      if ! echo "$META_COMP" | jq -e . >/dev/null 2>&1; then
        log "failed to read IMDS compute metadata"
        echo "$META_COMP"
        exit 1
      fi
      SUB_ID_FALLBACK=$(echo "$META_COMP" | jq -r '.subscriptionId')
      RG_FALLBACK=$(echo "$META_COMP" | jq -r '.resourceGroupName')
      VMSS_FALLBACK=$(echo "$META_COMP" | jq -r '.vmScaleSetName')
      VM_RESOURCE_ID=$(echo "$META_COMP" | jq -r '.resourceId')

      SUBSCRIPTION_ID="${azure_subscription_id}"
      RESOURCE_GROUP="${azure_resource_group}"
      VMSS_NAME="${azure_vmss_name}"

      if [ -z "$SUBSCRIPTION_ID" ]; then
        SUBSCRIPTION_ID="$SUB_ID_FALLBACK"
      fi
      if [ -z "$RESOURCE_GROUP" ]; then
        RESOURCE_GROUP="$RG_FALLBACK"
      fi
      if [ -z "$VMSS_NAME" ]; then
        VMSS_NAME="$VMSS_FALLBACK"
      fi

      TOKEN=""
      for attempt in $(seq 1 10); do
        TOKEN=$(curl -s -H Metadata:true "http://169.254.169.254/metadata/identity/oauth2/token?api-version=2018-02-01&resource=https://management.azure.com/&client_id=${identity_client_id}" | jq -r '.access_token // empty' 2>/dev/null || true)
        if [ -n "$TOKEN" ]; then
          break
        fi
        log "waiting for IMDS identity token (attempt $${attempt}/10)"
        sleep 2
      done
      if [ -z "$TOKEN" ]; then
        log "failed to obtain IMDS identity token"
        exit 1
      fi

      MGMT_IFACE=$(ip route show default | awk '{print $5}' | head -n1)
      if [ -z "$MGMT_IFACE" ]; then
        MGMT_IFACE=$(ip -4 -o addr show | awk '$2 != "lo" {print $2; exit}')
      fi
      if [ -z "$MGMT_IFACE" ]; then
        log "failed to identify management interface"
        exit 1
      fi

      MGMT_MAC=$(cat "/sys/class/net/$${MGMT_IFACE}/address" 2>/dev/null || true)
      if [ -z "$MGMT_MAC" ]; then
        log "failed to resolve management interface mac address"
        exit 1
      fi

      DATA_IFACE=""
      DATA_SYNTH_IFACE=""
      for attempt in $(seq 1 30); do
        for iface in /sys/class/net/*; do
          iface=$(basename "$iface")
          if [ "$iface" = "lo" ] || [ "$iface" = "$${MGMT_IFACE}" ]; then
            continue
          fi
          mac=$(cat "/sys/class/net/$${iface}/address" 2>/dev/null || true)
          if [ -z "$mac" ]; then
            continue
          fi
          if [ "$(normalize_mac "$mac")" != "$(normalize_mac "$MGMT_MAC")" ]; then
            if [ -z "$DATA_IFACE" ]; then
              DATA_IFACE="$iface"
            fi
            driver=$(iface_driver "$iface")
            if [ "$driver" = "hv_netvsc" ]; then
              DATA_SYNTH_IFACE="$iface"
            fi
          fi
        done
        if [ -n "$DATA_SYNTH_IFACE" ]; then
          DATA_IFACE="$DATA_SYNTH_IFACE"
          break
        fi
        if [ -n "$DATA_IFACE" ]; then
          break
        fi
        log "waiting for dataplane interface (attempt $${attempt}/30)"
        sleep 2
      done
      if [ -z "$DATA_IFACE" ]; then
        log "failed to identify dataplane interface"
        for iface in /sys/class/net/*; do
          iface=$(basename "$iface")
          mac=$(cat "/sys/class/net/$${iface}/address" 2>/dev/null || true)
          log "iface $${iface} mac=$${mac}"
        done
        exit 1
      fi

      DATA_MAC=$(cat "/sys/class/net/$${DATA_IFACE}/address" 2>/dev/null || true)
      if [ -z "$DATA_MAC" ]; then
        log "failed to resolve dataplane interface mac address"
        exit 1
      fi

      DATA_DRIVER=$(iface_driver "$DATA_IFACE")
      USE_NETVSC_PMD=0
      DATA_DHCP="true"
      if [ "$DATA_DRIVER" = "hv_netvsc" ]; then
        log "dataplane interface uses hv_netvsc; keeping DHCP enabled"
      fi

      ensure_dataplane_dhcp "$MGMT_MAC" "$DATA_MAC" "$DATA_DHCP"
      ip link set data0 up || true

      DATA_DEV="data0"

      NIC_URL="https://management.azure.com/subscriptions/$${SUBSCRIPTION_ID}/resourceGroups/$${RESOURCE_GROUP}/providers/Microsoft.Network/networkInterfaces?api-version=2023-09-01"
      NIC_JSON=""
      for attempt in $(seq 1 10); do
        NIC_JSON=$(curl -s -H "Authorization: Bearer $${TOKEN}" "$NIC_URL" || true)
        if echo "$NIC_JSON" | jq -e '.value' >/dev/null 2>&1; then
          break
        fi
        log "waiting for ARM NIC list (attempt $${attempt}/10)"
        sleep 2
      done

      if ! echo "$NIC_JSON" | jq -e '.value' >/dev/null 2>&1; then
        log "failed to list network interfaces in resource group"
        echo "$NIC_JSON"
        exit 1
      fi

      norm_mac() {
        echo "$1" | tr '[:upper:]' '[:lower:]' | tr -d ':-'
      }

      MGMT_MAC_NORM=$(norm_mac "$MGMT_MAC")
      DATA_MAC_NORM=$(norm_mac "$DATA_MAC")

      MGMT_NIC_ID=$(echo "$NIC_JSON" | jq -r --arg vm "$${VM_RESOURCE_ID}" --arg mac "$${MGMT_MAC_NORM}" \
        '.value[] | select(.properties.virtualMachine.id == $vm) | select((.properties.macAddress // "") | ascii_downcase | gsub("[-:]"; "") == $mac) | .id' | head -n1)
      DATA_NIC_ID=$(echo "$NIC_JSON" | jq -r --arg vm "$${VM_RESOURCE_ID}" --arg mac "$${DATA_MAC_NORM}" \
        '.value[] | select(.properties.virtualMachine.id == $vm) | select((.properties.macAddress // "") | ascii_downcase | gsub("[-:]"; "") == $mac) | .id' | head -n1)

      if [ -z "$MGMT_NIC_ID" ] || [ -z "$DATA_NIC_ID" ]; then
        log "failed to identify management/dataplane NICs in Azure"
        exit 1
      fi

      tag_nic() {
        local nic_id="$1"
        local tag_key="$2"
        local nic_url="https://management.azure.com$${nic_id}?api-version=2023-09-01"
        local current
        current=$(curl -s -H "Authorization: Bearer $${TOKEN}" "$nic_url")
        local payload
        payload=$(echo "$current" | jq --arg key "$tag_key" '.tags[$key] = "true" | {tags: .tags}')
        curl -s -X PATCH -H "Authorization: Bearer $${TOKEN}" -H "Content-Type: application/json" -d "$payload" "$nic_url" >/dev/null
      }

      tag_nic "$MGMT_NIC_ID" "neuwerk.io.management"
      tag_nic "$DATA_NIC_ID" "neuwerk.io.dataplane"

      if [ "$USE_NETVSC_PMD" = "1" ]; then
        log "binding netvsc device to uio_hv_generic for DPDK"
        DEV_UUID=$(basename "$(readlink /sys/class/net/$${DATA_IFACE}/device)")
        modprobe uio_hv_generic || true
        driverctl -b vmbus set-override "$${DEV_UUID}" uio_hv_generic || true
        echo "$${DEV_UUID}" > /sys/bus/vmbus/drivers/uio_hv_generic/new_id || true
        echo "$${DEV_UUID}" > /sys/bus/vmbus/drivers/hv_netvsc/unbind || true
        echo "$${DEV_UUID}" > /sys/bus/vmbus/drivers/uio_hv_generic/bind || true
        ip link set "$${DATA_IFACE}" down || true
      fi

      DATA_IFACE_SELECTOR="mac:$${DATA_MAC}"
      DATA_PCI=""

      if [ "$DATA_DRIVER" != "hv_netvsc" ]; then
        DATA_VF_IFACE=""
        MGMT_VF_IFACE=""
        for iface in /sys/class/net/*; do
          iface=$(basename "$iface")
          if [ "$iface" = "lo" ] || [ "$iface" = "$${DATA_IFACE}" ] || [ "$iface" = "$${MGMT_IFACE}" ]; then
            continue
          fi
          mac=$(cat "/sys/class/net/$${iface}/address" 2>/dev/null || true)
          if [ -z "$mac" ]; then
            continue
          fi
          if [ "$(normalize_mac "$mac")" = "$(normalize_mac "$MGMT_MAC")" ]; then
            MGMT_VF_IFACE="$iface"
          fi
          if [ "$(normalize_mac "$mac")" = "$(normalize_mac "$DATA_MAC")" ]; then
            driver=$(iface_driver "$iface")
            if [ "$driver" != "hv_netvsc" ]; then
              DATA_VF_IFACE="$iface"
            fi
          fi
        done

        MGMT_PCI=""
        if [ -n "$MGMT_VF_IFACE" ]; then
          MGMT_PCI=$(readlink -f "/sys/class/net/$${MGMT_VF_IFACE}/device" | awk -F/ '{print $NF}')
        fi

        if [ -n "$DATA_VF_IFACE" ]; then
          DATA_PCI=$(readlink -f "/sys/class/net/$${DATA_VF_IFACE}/device" | awk -F/ '{print $NF}')
          if [ -n "$DATA_PCI" ] && [ ! -e "/sys/bus/pci/devices/$${DATA_PCI}" ]; then
            log "dataplane VF device $${DATA_VF_IFACE} not exposed as PCI; using mac selector"
            DATA_PCI=""
          fi
        else
          log "dataplane VF netdev not found; falling back to PCI scan"
          CANDIDATES=$(lspci -Dnnd 15b3:1016 | awk '{print $1}')
          if [ -z "$CANDIDATES" ]; then
            log "failed to find Mellanox VF devices via lspci"
            exit 1
          fi
          if [ -n "$MGMT_PCI" ]; then
            DATA_PCI=$(echo "$CANDIDATES" | grep -v "$MGMT_PCI" | head -n1)
          else
            DATA_PCI=$(echo "$CANDIDATES" | head -n1)
          fi
        fi

        if [ -z "$DATA_PCI" ]; then
          DATA_DRIVER="mana"
        else
          DATA_DRIVER=$(readlink -f "/sys/bus/pci/devices/$${DATA_PCI}/driver" 2>/dev/null | awk -F/ '{print $NF}')
        fi

        if [ "$DATA_DRIVER" = "mana" ]; then
          log "mana driver detected on $${DATA_PCI}; skipping vfio-pci binding"
          DATA_IFACE_SELECTOR="mac:$${DATA_MAC}"
        else
          if lspci -Dnnd 15b3:1016 | awk '{print $1}' | grep -q "^$${DATA_PCI}$"; then
            log "mlx5 VF detected on $${DATA_PCI}; keeping kernel driver"
            modprobe mlx5_core || true
            modprobe mlx5_ib || true
            if [ "$DATA_DRIVER" = "vfio-pci" ]; then
              if [ -x /usr/bin/dpdk-devbind.py ]; then
                python3 /usr/bin/dpdk-devbind.py -b mlx5_core "$DATA_PCI"
              elif [ -x /usr/share/dpdk/usertools/dpdk-devbind.py ]; then
                python3 /usr/share/dpdk/usertools/dpdk-devbind.py -b mlx5_core "$DATA_PCI"
              fi
            fi
            DATA_IFACE_SELECTOR="pci:$${DATA_PCI}"
          else
            log "binding dataplane interface $${DATA_IFACE} ($${DATA_PCI}) to vfio-pci"
            DPDK_DEVBIND="/usr/bin/dpdk-devbind.py"
            if [ ! -x "$DPDK_DEVBIND" ]; then
              DPDK_DEVBIND="/usr/share/dpdk/usertools/dpdk-devbind.py"
            fi
            if [ ! -x "$DPDK_DEVBIND" ]; then
              log "dpdk-devbind.py not found"
              exit 1
            fi
            ip link set "$${DATA_IFACE}" down || true
            ip link set "$${DATA_VF_IFACE}" down || true
            python3 "$DPDK_DEVBIND" -b vfio-pci "$DATA_PCI"
            DATA_IFACE_SELECTOR="pci:$${DATA_PCI}"
          fi
        fi
      else
        log "skipping VF binding for netvsc dataplane; using netvsc vdev"
      fi

      log "dataplane selection: iface=$${DATA_IFACE} selector=$${DATA_IFACE_SELECTOR} driver=$${DATA_DRIVER} pci=$${DATA_PCI} netvsc_pmd=$${USE_NETVSC_PMD}"

      if ! command -v azcopy >/dev/null 2>&1; then
        log "installing azcopy"
        curl -L -o /tmp/azcopy.tar.gz https://aka.ms/downloadazcopy-v10-linux
        tar -xzf /tmp/azcopy.tar.gz -C /tmp
        cp /tmp/azcopy_linux_amd64_*/azcopy /usr/local/bin/azcopy
        chmod +x /usr/local/bin/azcopy
      fi

      log "downloading neuwerk binary from blob"
      azcopy login --identity --identity-client-id ${identity_client_id} >/dev/null 2>&1
      azcopy copy "https://${storage_account_name}.blob.core.windows.net/${storage_container_name}/${storage_blob_name}" /usr/local/bin/neuwerk --overwrite=true
      chmod +x /usr/local/bin/neuwerk

      MGMT_IP=$(ip -4 -o addr show dev "$MGMT_IFACE" | awk '{print $4}' | cut -d/ -f1)
      if [ -z "$MGMT_IP" ]; then
        log "failed to resolve management IP"
        exit 1
      fi

      DPDK_WORKERS="${dpdk_workers}"
      if ! [[ "$DPDK_WORKERS" =~ ^[0-9]+$ ]]; then
        DPDK_WORKERS=0
      fi

      FORCE_NETVSC=false
      if [ "$USE_NETVSC_PMD" = "1" ]; then
        FORCE_NETVSC=true
      fi

      cat > "$CONFIG_FILE" <<EOF_CONFIG
      version: 1
      bootstrap:
        management_interface: "$${MGMT_IFACE}"
        data_interface: "$${DATA_IFACE_SELECTOR}"
        cloud_provider: ${cloud_provider}
        data_plane_mode: dpdk
      dns:
        target_ips:
%{ for dns_target in dns_target_ips ~}
          - ${dns_target}
%{ endfor ~}
        upstreams:
%{ for dns_upstream in dns_upstreams ~}
          - "${dns_upstream}"
%{ endfor ~}
      policy:
        default: allow
        internal_cidr: ${internal_cidr}
      http:
        bind: "$${MGMT_IP}:8443"
        advertise: "$${MGMT_IP}:8443"
        external_url: "https://$${MGMT_IP}:8443"
      metrics:
        bind: "$${MGMT_IP}:8080"
      integration:
        mode: azure-vmss
        drain_timeout_secs: 30
        reconcile_interval_secs: 15
        azure:
          subscription_id: "$${SUBSCRIPTION_ID}"
          resource_group: "$${RESOURCE_GROUP}"
          vmss_name: "$${VMSS_NAME}"
      dataplane:
        snat: ${snat_mode}
        encap_mode: vxlan
        encap_vni_internal: ${gwlb_vni_internal}
        encap_vni_external: ${gwlb_vni_external}
        encap_udp_port_internal: ${gwlb_udp_port_internal}
        encap_udp_port_external: ${gwlb_udp_port_external}
        admission:
          max_active_flows: 24576
          max_active_nat_entries: 24576
          max_pending_tls_flows: 2048
          max_active_flows_per_source_group: 16384
      dpdk:
        tx_checksum_offload: false
        force_netvsc: $${FORCE_NETVSC}
        gateway_mac: 12:34:56:78:9a:bc
        overlay:
          swap_tunnels: false
          force_tunnel_src_port: false
%{ if dpdk_workers > 0 ~}
        workers: ${dpdk_workers}
%{ endif ~}
      EOF_CONFIG

      cat > "$HEALTH_ROUTE_STATE" <<EOF_STATE
      data_dev: $${DATA_DEV}
      EOF_STATE

      touch "$FIRSTBOOT_MARKER"
      systemctl daemon-reload
      systemctl enable --now neuwerk-health-route.service
      systemctl reset-failed neuwerk.service || true
      systemctl restart neuwerk.service --no-block

  - path: /usr/local/bin/neuwerk-health-route.sh
    permissions: "0755"
    content: |
      #!/usr/bin/env bash
      set -euo pipefail

      STATE_FILE="/var/lib/neuwerk/azure-health-route.yaml"
      if [ ! -f "$STATE_FILE" ]; then
        exit 0
      fi
      DATA_DEV="$(awk '$1 == "data_dev:" {print $2; exit}' "$STATE_FILE")"
      if [ -z "$${DATA_DEV:-}" ]; then
        exit 0
      fi

      DATA_IP=""
      for attempt in $(seq 1 30); do
        DATA_IP=$(ip -4 -o addr show dev "$DATA_DEV" 2>/dev/null | awk '{print $4}' | cut -d/ -f1 | head -n1)
        if [ -n "$DATA_IP" ]; then
          break
        fi
        echo "[neuwerk-health-route] waiting for dataplane IP (attempt $${attempt}/30)"
        sleep 2
      done
      if [ -z "$DATA_IP" ]; then
        echo "[neuwerk-health-route] dataplane IP not found; skipping route update"
        exit 0
      fi

      DATA_GW="$${DATA_IP%.*}.1"
      ip route replace 168.63.129.16/32 via "$DATA_GW" dev "$DATA_DEV" src "$DATA_IP" metric 50
      echo "[neuwerk-health-route] routed 168.63.129.16/32 via $${DATA_DEV} ($${DATA_IP})"

  - path: /etc/systemd/system/neuwerk-health-route.service
    permissions: "0644"
    content: |
      [Unit]
      Description=Route Azure LB health probes via dataplane NIC
      After=network-online.target
      Wants=network-online.target

      [Service]
      Type=oneshot
      ExecStart=/usr/local/bin/neuwerk-health-route.sh
      RemainAfterExit=yes

      [Install]
      WantedBy=multi-user.target

  - path: /etc/systemd/system/neuwerk-firstboot.service
    permissions: "0644"
    content: |
      [Unit]
      Description=Neuwerk first boot preparation
      After=network-online.target
      Wants=network-online.target

      [Service]
      Type=oneshot
      ExecStart=/usr/local/bin/neuwerk-firstboot.sh
      RemainAfterExit=yes

      [Install]
      WantedBy=multi-user.target

  - path: /etc/systemd/system/neuwerk.service
    permissions: "0644"
    content: |
      [Unit]
      Description=Neuwerk
      After=network-online.target neuwerk-firstboot.service
      Wants=network-online.target
      Requires=neuwerk-firstboot.service

      [Service]
      Type=simple
      ExecStart=/usr/local/bin/neuwerk
      Restart=on-failure
      LimitMEMLOCK=infinity

      [Install]
      WantedBy=multi-user.target

runcmd:
  - systemctl daemon-reload
  - ethtool -K data0 rx off tx off gro off gso off tso off lro off || true
  - systemctl enable neuwerk-health-route.service
  - systemctl enable neuwerk-firstboot.service
  - systemctl enable neuwerk.service
  - systemctl start neuwerk-firstboot.service
